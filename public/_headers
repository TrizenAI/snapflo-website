# index.html — never cache, always fetch fresh
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Hashed JS/CSS assets — cache forever (Vite puts content hash in filename)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts — cache for 1 year
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Public images — cache for 30 days
/*.png
  Cache-Control: public, max-age=2592000, must-revalidate

/*.jpg
  Cache-Control: public, max-age=2592000, must-revalidate

/images/*
  Cache-Control: public, max-age=2592000, must-revalidate

# sitemap & robots — revalidate daily
/sitemap.xml
  Cache-Control: public, max-age=86400, must-revalidate

/robots.txt
  Cache-Control: public, max-age=86400, must-revalidate
